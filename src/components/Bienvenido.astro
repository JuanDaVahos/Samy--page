---
import ImgWelcome from "../assets/Images/ImgWelcome.webp";
import Image from "astro/components/Image.astro";
import CalendarySvg from "../assets/svg/Calendary.svg";
import ClockSvg from "../assets/svg/Clock.svg";

// FECHA
const fechaCortaCo = new Date().toLocaleDateString("es-CO", {
  day: "numeric",
  month: "numeric",
  year: "numeric",
  timeZone: "America/Bogota",
});
---

<section
  class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-4 sm:p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
>
  <!-- Imagen -->
  <div class="flex justify-center">
    <Image
      src={ImgWelcome}
      alt="Imagen de Bienvenida, Un helado Alegre"
      width={250}
      height={250}
      class="drop-shadow-lg"
    />
  </div>

  <!-- Información -->
  <div class="flex flex-col items-center md:items-start">
    <h1
      class="flex flex-wrap justify-center md:justify-start items-center gap-3 text-center text-3xl md:text-5xl font-bold text-black"
    >
      <span>¡Bienvenido!</span>
      <span>🍦</span>
    </h1>

    <p class="mt-2 text-center text-lg text-gray-700 md:text-left">
      Aquí tienes el resumen general de la Heladería
    </p>

    <!-- Fecha y Hora -->
    <div
      class="mt-8 flex flex-wrap items-center justify-center gap-6 md:justify-start"
    >
      <div
        class="flex items-center gap-3 rounded-xl bg-white px-4 py-3 shadow-sm"
      >
        <CalendarySvg class="h-8 w-8" />

        <div>
          <p class="text-sm text-gray-500">Fecha</p>
          <strong class="text-samy">{fechaCortaCo}</strong>
        </div>
      </div>

      <div
        class="flex items-center gap-3 rounded-xl bg-white px-4 py-3 shadow-sm"
      >
        <ClockSvg class="h-8 w-8" />

        <div>
          <p class="text-sm text-gray-500">Hora</p>
          <!-- id para que el script actualice la hora en tiempo real -->
          <strong id="hora-medellin" class="text-samy">--:--</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Hora
  function actualizarHora() {
    const el = document.getElementById("hora-medellin");
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString("es-CO", {
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "America/Bogota",
    });
  }

  actualizarHora();
  setInterval(actualizarHora, 30000);
</script>
