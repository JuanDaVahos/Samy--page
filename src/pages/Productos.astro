---
import Header from "../sections/Header.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../sections/Footer.astro";
---

<Layout>
  <Header />

  <main class="flex flex-1 flex-col items-center justify-center min-h-[60vh] gap-4 px-4">
    <div class="flex flex-col items-center gap-3 rounded-3xl border border-pink-200 bg-white/60 px-12 py-10 shadow-sm backdrop-blur-sm text-center">
      <span class="text-5xl">🚧</span>
      <h2 class="text-2xl font-bold text-gray-800">En proceso</h2>
      <p class="text-gray-500">Esta sección estará disponible próximamente.</p>
    </div>
  </main>

  <Footer />
</Layout>
